digraph OrdinaryQuerySequence {
  graph [rankdir=TB, bgcolor="transparent", pad="0.25", nodesep="0.25", ranksep="0.42"];
  node [
    shape=box,
    style="rounded,filled",
    color="#3B5B7A",
    fillcolor="#EAF2F8",
    fontcolor="#172B3A",
    fontname="Helvetica",
    fontsize=10
  ];
  edge [color="#566573", fontcolor="#34495E", fontname="Helvetica", fontsize=9];

  register [label="1. register()\nvalidate spec + prepare"];
  validate [label="2. validate query\nfields, bounds, universe"];
  scan [label="3. backend.scan()\nprojection + pushdown"];
  keys [label="4. validate keys\nno null keys", fillcolor="#E8F6F3"];
  adjust [label="5. adjust prices\nwhen configured", fillcolor="#FCF3CF"];
  convert [label="6. panel pivot\nor table metadata", fillcolor="#FDEBD0"];
  audit [label="7. atomic audit\nstatus + provenance + shape", fillcolor="#FADBD8"];

  register -> validate -> scan -> keys -> adjust -> convert -> audit;
  validate -> audit [style=dashed, label="failure"];
  scan -> audit [style=dashed, label="failure"];
}
